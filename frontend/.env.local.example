# frontend/.env.local.example
# Copy to .env.local and fill in values. Never commit .env.local.
# See infra/env-vars-reference.toml for full reference.

# BLK-4 fix: canonical name is NEXT_PUBLIC_API_BASE_URL
# (was NEXT_PUBLIC_API_URL in original frontend code — corrected)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

NEXT_PUBLIC_APP_ENV=local

# Sentry — leave empty to disable locally
NEXT_PUBLIC_SENTRY_DSN=
# Internal server-to-server URL (avoids going through the public internet on SSR)
# In Docker Compose this is typically http://backend:8000/api/v1
API_INTERNAL_URL=http://localhost:8000/api/v1